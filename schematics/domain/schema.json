{
  "$schema": "http://json-schema.org/schema",
  "$id": "CapacitorTypeormSqliteDomainSchema",
  "title": "Capacitor TypeORM SQLite Domain Options",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Domain name, for example user or order.",
      "$default": {
        "$source": "argv",
        "index": 0
      }
    },
    "project": {
      "type": "string",
      "description": "Angular project name. Defaults to the first application project."
    },
    "tableName": {
      "type": "string",
      "description": "Database table name. Defaults to the dasherized domain name."
    },
    "skipRegistration": {
      "type": "boolean",
      "description": "Skip updating database.config.ts and application.providers.ts.",
      "default": false
    }
  },
  "required": ["name"],
  "additionalProperties": false
}
