{
  "compilerOptions": {
    "declaration": false,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmitOnError": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["schematics/**/*.ts"],
  "exclude": ["schematics/**/*.js", "schematics/**/files/**"]
}
