{
  "name": "capacitor-typeorm-sqlite-ng",
  "version": "1.0.0-rc.2",
  "description": "Angular schematics for Capacitor SQLite and TypeORM architecture.",
  "license": "MIT",
  "keywords": [
    "angular",
    "schematics",
    "capacitor",
    "typeorm",
    "sqlite",
    "android",
    "ports-and-adapters"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/waliu/capacitor-typeorm-sqlite-ng.git"
  },
  "bugs": {
    "url": "https://github.com/waliu/capacitor-typeorm-sqlite-ng/issues"
  },
  "homepage": "https://github.com/waliu/capacitor-typeorm-sqlite-ng#readme",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:web": "ng build",
    "build:native": "ng build --configuration production,native",
    "schematics:build": "tsc -p tsconfig.schematics.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "typeorm:patch": "node ./scripts/modify-typeorm.cjs",
    "cap:sync": "npm run build:native && npx cap sync",
    "cap:android": "npm run build:native && npx cap sync android",
    "prepack": "npm run schematics:build",
    "postinstall": "npm run typeorm:patch"
  },
  "private": false,
  "schematics": "./schematics/collection.json",
  "files": [
    "README.md",
    "schematics",
    "scripts/modify-typeorm.cjs"
  ],
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "~7.8.0",
    "sql.js": "^1.10.3",
    "tslib": "^2.3.0",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "^22.0.0",
    "@angular-devkit/schematics": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@types/node": "^24.13.1",
    "@types/sql.js": "^1.4.9",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
